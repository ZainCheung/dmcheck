# dmcheck runtime configuration
#
# Copy to /opt/dmcheck/dmcheck.env when using deploy/dmcheck.service.
# Unset values use the application defaults documented in README.md.

PORT=3300
REDIS_ADDR=localhost:6379
RATE_LIMIT=2
RATE_BURST=5
AVAILABLE_CACHE_TTL=0
REGISTERED_CACHE_TTL=2160h
REGISTRAR_PRICES_ENABLED=false
GA_ID=
SITE_URL=https://dmcheck.app
# Leave empty to show the build/git-derived version in the UI.
APP_VERSION=
